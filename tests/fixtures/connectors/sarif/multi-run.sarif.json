{
  "$schema": "https://raw.githubusercontent.com/oasis-tcs/sarif-spec/main/sarif-2.1/schema/sarif-schema-2.1.0.json",
  "version": "2.1.0",
  "runs": [
    {
      "tool": {
        "driver": {
          "name": "Scanner1",
          "version": "2.0.0"
        }
      },
      "results": [
        {
          "ruleId": "S1-001",
          "level": "error",
          "message": { "text": "First scanner finding" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "app/main.py" },
                "region": { "startLine": 10 }
              }
            }
          ]
        }
      ]
    },
    {
      "tool": {
        "driver": {
          "name": "Scanner2",
          "version": "3.0.0"
        }
      },
      "results": [
        {
          "ruleId": "S2-001",
          "level": "warning",
          "message": { "text": "Second scanner finding" },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": { "uri": "lib/utils.py" },
                "region": { "startLine": 25 }
              }
            }
          ]
        }
      ]
    }
  ]
}
